{% extends 'base.html.twig' %}

{% block title %}Hello SignupController!{% endblock %}

{% block body %}
<section class="w-full bg-gray-200">
    
        <div class="w-full bg-white lg:w-6/12 xl:w-5/12 mx-auto">
            <div class="flex flex-col items-start justify-start w-full h-full p-10 lg:p-16 xl:p-24">
                <h4 class="w-full text-3xl font-bold">Inscrivez-vous</h4>
                <p class="text-lg text-gray-500">ou, si vous avez déja un compte, vous pouvez vous <a href="/signin" class="text-green-700 underline" data-primary="green-700">connecter ici</a></p>
                <div class="relative w-full mt-10 space-y-8">
                    <div class="relative">
                        <label class="font-medium text-gray-900">Nom</label>
                        <input type="text" class="block w-full px-4 py-4 mt-2 text-xl placeholder-gray-400 bg-gray-200 rounded-lg focus:outline-none focus:ring-4 focus:ring-blue-600 focus:ring-opacity-50" data-primary="blue-600" data-rounded="rounded-lg" placeholder="Entrer Votre Nom" />
                    </div>
                    <div class="relative">
                        <label class="font-medium text-gray-900">Prénom</label>
                        <input type="text" class="block w-full px-4 py-4 mt-2 text-xl placeholder-gray-400 bg-gray-200 rounded-lg focus:outline-none focus:ring-4 focus:ring-blue-600 focus:ring-opacity-50" data-primary="blue-600" data-rounded="rounded-lg" placeholder="Entrer Votre Prénom" />
                    </div>
                    <div class="relative">
                        <label class="font-medium text-gray-900">Email</label>
                        <input type="text" class="block w-full px-4 py-4 mt-2 text-xl placeholder-gray-400 bg-gray-200 rounded-lg focus:outline-none focus:ring-4 focus:ring-blue-600 focus:ring-opacity-50" data-primary="blue-600" data-rounded="rounded-lg" placeholder="Entrer Votre Adresse Email" />
                    </div>
                    <div class="relative">
                        <label class="font-medium text-gray-900">Mot de passe</label>
                        <input type="password" class="block w-full px-4 py-4 mt-2 text-xl placeholder-gray-400 bg-gray-200 rounded-lg focus:outline-none focus:ring-4 focus:ring-blue-600 focus:ring-opacity-50" data-primary="blue-600" data-rounded="rounded-lg" placeholder="Mot de Passe" />
                    </div>
                    <div class="relative">
                        <a href="#_" class="inline-block w-full px-5 py-4 text-lg font-medium text-center text-white transition duration-200 bg-green-700 rounded-lg hover:bg-green-800 ease" data-primary="green-700" data-rounded="rounded-lg">S'isncrire</a>
                        
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


{% endblock %}
